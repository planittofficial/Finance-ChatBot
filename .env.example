# ──────────────────────────────────────────────
#  FinanceAI Chatbot — Environment Variables
# ──────────────────────────────────────────────
#  Copy this file to .env and fill in the values

# Groq API Key (get yours at https://console.groq.com)
GROQ_API_KEY=gsk_your_api_key_here

# Server config
PORT=3000
NODE_ENV=development

# CORS — comma-separated list of allowed origins
# Use * for development, restrict for production
CORS_ORIGINS=http://localhost:5678,http://127.0.0.1:5678

# Rate limiting (requests per window per IP)
RATE_LIMIT_WINDOW_MS=60000
RATE_LIMIT_MAX_REQUESTS=30

# Session TTL in milliseconds (default: 30 minutes)
SESSION_TTL_MS=1800000

# Groq model selection
GROQ_MODEL=llama-3.3-70b-versatile
GROQ_ANALYSIS_TEMPERATURE=0.3
GROQ_CHAT_TEMPERATURE=0.65

# Advisor details shown after recommendations
ADVISOR_NAME=
ADVISOR_REGISTRATION=
ADVISOR_PHONE=
ADVISOR_EMAIL=
ADVISOR_COMPANY=
